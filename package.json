{
  "name": "depup",
  "version": "1.0.0",
  "description": "Check npm/pnpm dependencies for updates with custom registry support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "depup": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "dependency",
    "update",
    "outdated",
    "cli",
    "pnpm",
    "workspace",
    "registry"
  ],
  "author": {
    "name": "Conner Bachmann",
    "email": "github@conner-bachmann.de"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "ora": "^9.4.0",
    "semver": "^7.7.2",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/semver": "^7.5.8",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.7.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
